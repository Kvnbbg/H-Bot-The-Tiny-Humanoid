<?xml version="1.0"?>
<!--
  H-Bot: The Tiny Humanoid — minimal URDF description.

  This file defines a 13-DOF (head + arms + legs) humanoid robot using
  standard URDF revolute joints.  It is intentionally kept simple so it can
  be loaded by pure-Python XML parsers, ROS / RViz, or Gazebo without
  requiring extra ROS packages at edit time.

  Joint convention (ROS standard right-handed frame, units in meters & radians):
    x : forward
    y : left
    z : up

  Required links : base_link, torso, head,
                   left_upper_arm, left_lower_arm,
                   right_upper_arm, right_lower_arm,
                   left_thigh, left_shin, left_foot,
                   right_thigh, right_shin, right_foot.

  Required joints: head_pan,
                   left_shoulder_pitch, left_elbow,
                   right_shoulder_pitch, right_elbow,
                   left_hip_yaw, left_hip_pitch, left_knee, left_ankle,
                   right_hip_yaw, right_hip_pitch, right_knee, right_ankle.

  NOTE: ROS does not need to be installed to edit or inspect this file.
        If you want to validate or visualize it:
          sudo apt install ros-noetic-urdfdom-py
          python3 -c "import urdf_parser_py.urdf; print(urdf_parser_py.urdf.URDF.load('h_bot.urdf'))"
-->
<robot name="h_bot">

  <!-- ===================== Materials ===================== -->
  <material name="h_bot_dark">
    <color rgba="0.15 0.18 0.22 1.0"/>
  </material>
  <material name="h_bot_green">
    <color rgba="0.06 0.73 0.49 1.0"/>
  </material>
  <material name="h_bot_joint">
    <color rgba="0.3 0.3 0.35 1.0"/>
  </material>

  <!-- ===================== Base / Torso ===================== -->
  <link name="base_link">
    <!-- Virtual root link.  It anchors the robot in the world. -->
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>

  <joint name="base_to_torso" type="fixed">
    <parent link="base_link"/>
    <child link="torso"/>
    <origin xyz="0 0 0.30" rpy="0 0 0"/>
  </joint>

  <link name="torso">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.10 0.14 0.20"/>
      </geometry>
      <material name="h_bot_green"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.10 0.14 0.20"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.55"/>
      <inertia ixx="0.00192" ixy="0" ixz="0" iyy="0.00150" iyz="0" izz="0.00142"/>
    </inertial>
  </link>

  <!-- ===================== Head ===================== -->
  <joint name="head_pan" type="revolute">
    <parent link="torso"/>
    <child link="head"/>
    <origin xyz="0 0 0.12" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.094" upper="2.094" effort="0.5" velocity="3.0"/>
  </joint>

  <link name="head">
    <visual>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
      <material name="h_bot_dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <mass value="0.10"/>
      <inertia ixx="6.5e-5" ixy="0" ixz="0" iyy="6.5e-5" iyz="0" izz="6.5e-5"/>
    </inertial>
  </link>

  <!-- ===================== Left Arm ===================== -->
  <joint name="left_shoulder_pitch" type="revolute">
    <parent link="torso"/>
    <child link="left_upper_arm"/>
    <origin xyz="0 0.085 0.08" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.571" upper="1.571" effort="0.8" velocity="3.0"/>
  </joint>

  <link name="left_upper_arm">
    <visual>
      <origin xyz="0 0 -0.06" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.018" length="0.12"/>
      </geometry>
      <material name="h_bot_dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.06" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.018" length="0.12"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.06" rpy="0 0 0"/>
      <mass value="0.08"/>
      <inertia ixx="1.1e-4" ixy="0" ixz="0" iyy="1.1e-4" iyz="0" izz="1.3e-6"/>
    </inertial>
  </link>

  <joint name="left_elbow" type="revolute">
    <parent link="left_upper_arm"/>
    <child link="left_lower_arm"/>
    <origin xyz="0 0 -0.12" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.094" upper="0.0" effort="0.6" velocity="3.0"/>
  </joint>

  <link name="left_lower_arm">
    <visual>
      <origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.015" length="0.10"/>
      </geometry>
      <material name="h_bot_green"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.015" length="0.10"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="4.6e-5" ixy="0" ixz="0" iyy="4.6e-5" iyz="0" izz="5.6e-7"/>
    </inertial>
  </link>

  <!-- ===================== Right Arm ===================== -->
  <joint name="right_shoulder_pitch" type="revolute">
    <parent link="torso"/>
    <child link="right_upper_arm"/>
    <origin xyz="0 -0.085 0.08" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.571" upper="1.571" effort="0.8" velocity="3.0"/>
  </joint>

  <link name="right_upper_arm">
    <visual>
      <origin xyz="0 0 -0.06" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.018" length="0.12"/>
      </geometry>
      <material name="h_bot_dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.06" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.018" length="0.12"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.06" rpy="0 0 0"/>
      <mass value="0.08"/>
      <inertia ixx="1.1e-4" ixy="0" ixz="0" iyy="1.1e-4" iyz="0" izz="1.3e-6"/>
    </inertial>
  </link>

  <joint name="right_elbow" type="revolute">
    <parent link="right_upper_arm"/>
    <child link="right_lower_arm"/>
    <origin xyz="0 0 -0.12" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.094" upper="0.0" effort="0.6" velocity="3.0"/>
  </joint>

  <link name="right_lower_arm">
    <visual>
      <origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.015" length="0.10"/>
      </geometry>
      <material name="h_bot_green"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.015" length="0.10"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="4.6e-5" ixy="0" ixz="0" iyy="4.6e-5" iyz="0" izz="5.6e-7"/>
    </inertial>
  </link>

  <!-- ===================== Left Leg ===================== -->
  <!--
    A tiny hip yaw link lets us keep the hip_yaw and hip_pitch joints
    at the same physical location without merging them into one DOF.
  -->
  <joint name="left_hip_yaw" type="revolute">
    <parent link="torso"/>
    <child link="left_hip_yaw_link"/>
    <origin xyz="0 0.04 -0.10" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.785" upper="0.785" effort="1.0" velocity="3.0"/>
  </joint>

  <link name="left_hip_yaw_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.02"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>

  <joint name="left_hip_pitch" type="revolute">
    <parent link="left_hip_yaw_link"/>
    <child link="left_thigh"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.571" upper="1.571" effort="1.0" velocity="3.0"/>
  </joint>

  <link name="left_thigh">
    <visual>
      <origin xyz="0 0 -0.075" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.15"/>
      </geometry>
      <material name="h_bot_dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.075" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.15"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.075" rpy="0 0 0"/>
      <mass value="0.12"/>
      <inertia ixx="2.5e-4" ixy="0" ixz="0" iyy="2.5e-4" iyz="0" izz="3.8e-6"/>
    </inertial>
  </link>

  <joint name="left_knee" type="revolute">
    <parent link="left_thigh"/>
    <child link="left_shin"/>
    <origin xyz="0 0 -0.15" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0.0" upper="2.094" effort="1.0" velocity="3.0"/>
  </joint>

  <link name="left_shin">
    <visual>
      <origin xyz="0 0 -0.075" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.020" length="0.15"/>
      </geometry>
      <material name="h_bot_green"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.075" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.020" length="0.15"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.075" rpy="0 0 0"/>
      <mass value="0.10"/>
      <inertia ixx="2.0e-4" ixy="0" ixz="0" iyy="2.0e-4" iyz="0" izz="2.0e-6"/>
    </inertial>
  </link>

  <joint name="left_ankle" type="revolute">
    <parent link="left_shin"/>
    <child link="left_foot"/>
    <origin xyz="0 0 -0.15" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.785" upper="0.785" effort="1.0" velocity="3.0"/>
  </joint>

  <link name="left_foot">
    <visual>
      <origin xyz="0.03 0 -0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.12 0.06 0.04"/>
      </geometry>
      <material name="h_bot_dark"/>
    </visual>
    <collision>
      <origin xyz="0.03 0 -0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.12 0.06 0.04"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.03 0 -0.02" rpy="0 0 0"/>
      <mass value="0.07"/>
      <inertia ixx="1.1e-5" ixy="0" ixz="0" iyy="8.7e-5" iyz="0" izz="9.3e-5"/>
    </inertial>
  </link>

  <!-- ===================== Right Leg ===================== -->
  <joint name="right_hip_yaw" type="revolute">
    <parent link="torso"/>
    <child link="right_hip_yaw_link"/>
    <origin xyz="0 -0.04 -0.10" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.785" upper="0.785" effort="1.0" velocity="3.0"/>
  </joint>

  <link name="right_hip_yaw_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.02"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>

  <joint name="right_hip_pitch" type="revolute">
    <parent link="right_hip_yaw_link"/>
    <child link="right_thigh"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.571" upper="1.571" effort="1.0" velocity="3.0"/>
  </joint>

  <link name="right_thigh">
    <visual>
      <origin xyz="0 0 -0.075" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.15"/>
      </geometry>
      <material name="h_bot_dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.075" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.15"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.075" rpy="0 0 0"/>
      <mass value="0.12"/>
      <inertia ixx="2.5e-4" ixy="0" ixz="0" iyy="2.5e-4" iyz="0" izz="3.8e-6"/>
    </inertial>
  </link>

  <joint name="right_knee" type="revolute">
    <parent link="right_thigh"/>
    <child link="right_shin"/>
    <origin xyz="0 0 -0.15" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0.0" upper="2.094" effort="1.0" velocity="3.0"/>
  </joint>

  <link name="right_shin">
    <visual>
      <origin xyz="0 0 -0.075" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.020" length="0.15"/>
      </geometry>
      <material name="h_bot_green"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.075" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.020" length="0.15"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.075" rpy="0 0 0"/>
      <mass value="0.10"/>
      <inertia ixx="2.0e-4" ixy="0" ixz="0" iyy="2.0e-4" iyz="0" izz="2.0e-6"/>
    </inertial>
  </link>

  <joint name="right_ankle" type="revolute">
    <parent link="right_shin"/>
    <child link="right_foot"/>
    <origin xyz="0 0 -0.15" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.785" upper="0.785" effort="1.0" velocity="3.0"/>
  </joint>

  <link name="right_foot">
    <visual>
      <origin xyz="0.03 0 -0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.12 0.06 0.04"/>
      </geometry>
      <material name="h_bot_dark"/>
    </visual>
    <collision>
      <origin xyz="0.03 0 -0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.12 0.06 0.04"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.03 0 -0.02" rpy="0 0 0"/>
      <mass value="0.07"/>
      <inertia ixx="1.1e-5" ixy="0" ixz="0" iyy="8.7e-5" iyz="0" izz="9.3e-5"/>
    </inertial>
  </link>

</robot>
